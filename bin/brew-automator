#!/usr/bin/env python3
"""Executable wrapper so brew-automator can run without installing the package
(makes the repo root importable, then delegates to brew_automator.cli.main)."""
import os
import sys

sys.path.insert(0, os.path.join(os.path.dirname(os.path.abspath(__file__)), ".."))

from brew_automator.cli import main

if __name__ == "__main__":
    main()
